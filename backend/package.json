{
  "name": "distributed-ecom-backend",
  "version": "1.0.0",
  "description": "Distributed E-Commerce Backend with gRPC, Redis, WebSocket",
  "main": "gateway/gateway.js",
  "scripts": {
    "start": "node gateway/gateway.js",
    "dev": "nodemon gateway/gateway.js",
    "start:proxy": "node proxy/server.js",
    "start:auth": "node auth/authServer.js",
    "start:cache1": "CACHE_NODE_PORT=50052 node node/cacheNode.js",
    "start:cache2": "CACHE_NODE_PORT=50053 node node/cacheNode.js",
    "start:cache3": "CACHE_NODE_PORT=50054 node node/cacheNode.js",
    "start:ws": "node websocket/wsServer.js",
    "docker:up": "docker-compose up --build",
    "docker:down": "docker-compose down",
    "seed": "node seed.js"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.10.0",
    "@grpc/proto-loader": "^0.7.10",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.0.3",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "razorpay": "^2.9.2",
    "socket.io": "^4.6.2",
    "uuid": "^9.0.1",
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
