# Server Ports
GATEWAY_PORT=5000
PROXY_PORT=4000

# MongoDB
MONGO_URI=mongodb://localhost:27017/ecom_distributed

# JWT
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES=7d

# Razorpay — get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=rzp_test_XXXXXXXXXXXXXXXX
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_optional

# gRPC Cache Nodes (comma-separated host:port)
CACHE_NODES=localhost:50052,localhost:50053,localhost:50054
CACHE_CAPACITY=1000

# CORS — your frontend origin
CLIENT_URL=http://localhost:5173

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
